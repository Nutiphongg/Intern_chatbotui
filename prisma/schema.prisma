generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model sessions {
  id            String    @id
  user_id       String
  refresh_token String    @unique
  user_agent    String?
  ip_address    String?   @db.VarChar(50)
  expires_at    DateTime  @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([refresh_token], map: "idx_sessions_refresh_token")
  @@index([user_id], map: "idx_sessions_user_id")
}

model users {
  id            String          @id
  email         String          @unique @db.VarChar(255)
  username      String          @unique @db.VarChar(100)
  password_hash String
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  conversations conversations[]
  sessions      sessions[]
  user_apikey   user_apikey[]
  conversation_memory_chunks conversation_memory_chunks[]

  @@index([email], map: "idx_users_email")
  @@index([username], map: "idx_users_username")
}

model conversations {
  id              String     @id
  user_id         String?
  title           String?
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  updated_at      DateTime?  @default(now()) @db.Timestamp(6)
  last_message_at DateTime?  @db.Timestamp(6)
  is_deleted      Boolean    @default(false)
  is_from_guest   Boolean    @default(false)
  users           users?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_user")
  messages        messages[]
  conversation_api_keys conversation_api_keys?
  conversation_memory_chunks conversation_memory_chunks[]

  @@index([last_message_at(sort: Desc)], map: "idx_conversations_last_message")
  @@index([user_id], map: "idx_conversations_user_id")
}

model messages {
  id              String        @id
  conversation_id String
  role            String        @db.VarChar(20)
  content         String
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  model           String?       @db.VarChar(50)
  token_usage     Int?
  response_time   Int?
  metadata        Json?
  deleted_at      DateTime?
  is_generate     Boolean       @default(false)
  is_silent_retry Boolean       @default(false)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_message_conversation")
  conversation_memory_chunks conversation_memory_chunks[]

  @@index([conversation_id], map: "idx_messages_conversation_id")
  @@index([created_at(sort: Desc)], map: "idx_messages_created_at")
  @@index([deleted_at])
}

model SystemSettings {
  id                Int    @id @default(1)
  userAccessExpiry  String @default("10m") @map("user_access_expiry")
  guestAccessExpiry String @default("1h") @map("guest_access_expiry")
  refreshExpiry     String @default("7d") @map("refresh_expiry")

  @@map("system_settings")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mapconfig {
  id                  String   @id(map: "UserMapConfig_pkey")
  intentName          String
  provider            String
  baseUrl             String
  urlTemplate         String
  layerConfigTemplate Json?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@unique([intentName, provider])
}

model mapconfig_hosts {
  id          String        @id
  provider    String
  hostname    String
  baseUrl     String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  user_apikey user_apikey[]

  @@unique([provider, hostname])
  @@index([provider])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_apikey {
  id           String    @id(map: "UserApiKey_pkey")
  userId       String    @map("user_id")
  provider     String
  hostId       String?
  keyName      String
  encryptedKey String
  iv           String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  keyHash      String?   @db.VarChar(64)
  deletedAt    DateTime?
  users        users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_apikey_user")
  mapconfig_hosts mapconfig_hosts? @relation(fields: [hostId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_user_apikey_mapconfig_host")
  conversation_api_keys conversation_api_keys[]

  @@index([userId], map: "idx_user_apikey_user_id")
  @@index([hostId], map: "idx_user_apikey_host_id")
  @@index([userId, provider, keyName], map: "idx_user_apikey_user_provider_key_name")
  @@index([keyHash], map: "idx_user_apikey_key_hash")
  @@index([deletedAt], map: "idx_user_apikey_deleted_at")
}

model conversation_api_keys {
  id             String        @id
  conversationId String        @unique
  userApiKeyId   String
  conversations  conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_api_keys_conversation")
  user_apikey    user_apikey   @relation(fields: [userApiKeyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_api_keys_user_apikey")

  @@index([userApiKeyId], map: "idx_conversation_api_keys_user_api_key_id")
}

model conversation_memory_chunks {
  id             String        @id
  conversationId String        @map("conversation_id")
  userId         String?       @map("user_id")
  messageId      String?       @map("message_id")
  sourceHash     String        @unique @map("source_hash") @db.VarChar(64)
  chunkType      String        @map("chunk_type") @db.VarChar(40)
  role           String?       @db.VarChar(20)
  content        String
  eventType      String?       @map("event_type") @db.VarChar(80)
  layerId        String?       @map("layer_id")
  styleKey       String?       @map("style_key")
  geometryType   String?       @map("geometry_type") @db.VarChar(40)
  metadata       Json?
  embedding      Unsupported("vector")?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  conversations  conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_memory_chunks_conversation")
  users          users?        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_memory_chunks_user")
  messages       messages?     @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation_memory_chunks_message")

  @@index([conversationId, createdAt(sort: Desc)], map: "idx_conversation_memory_chunks_conversation_created")
  @@index([userId], map: "idx_conversation_memory_chunks_user")
  @@index([messageId], map: "idx_conversation_memory_chunks_message")
  @@index([eventType], map: "idx_conversation_memory_chunks_event")
  @@index([layerId], map: "idx_conversation_memory_chunks_layer")
  @@index([styleKey], map: "idx_conversation_memory_chunks_style")
}
